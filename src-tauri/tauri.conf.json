{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Murcia",
  "version": "1.0.1",
  "identifier": "com.ceartee.murcia",
  
  "build": {
  
    "frontendDist": "../src"
  },
  
  "app": {
    
    "withGlobalTauri": false,
    
    "windows": [
      {
        "title": "CEARTEE - Murcia",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "center": true,
        
        "devtools": true
      }
    ],
    
    "security": {
      
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.githubusercontent.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com; object-src 'none'; frame-src 'none';"
    }
  },
  
  "bundle": {
  "active": true,
  "createUpdaterArtifacts": true,
  "targets": ["nsis"],

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    
    "resources": [],
    "category": "Education",
    "publisher": "CEARTEE",
    "copyright": "© 2024 CEARTEE",
    "homepage": "https://cearteesinaloa.blogspot.mx",
    "shortDescription": "Plataforma educativa CEARTEE",
    "longDescription": "Aplicación educativa para inclusión y aprendizaje interactivo.",
    "licenseFile": "assets/installer/LICENSE.txt",
    
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        
        "silent": true
      },
      
      "nsis": {
       
        "installMode": "currentUser",
        "languages": ["Spanish"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "bundles/nsis/header.bmp",
  "sidebarImage": "bundles/nsis/sidebar.bmp"
        
        
      }
    }
  },
  
  "plugins": {
    "updater": {
  "active": true,
  "dialog": false,
  "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxOUE0MzY3ODZGNjI2NUYKUldSZkp2YUdaME9ha1krWWNibW9PMjZlMmhXRVNNR24xYlNVcWFEU3pZTGNsVDFFVk9NTlZTRG0K",
  "endpoints": [
    "https://raw.githubusercontent.com/Yolito935/ceartee/main/latest.json"
  ],
  "windows": {
    "installMode": "quiet"
  }
}
  }
}